<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!--
        Generated by the maui-app-design skill.
        Mood: energetic / friendly. Harmony: complementary (orange + teal).
        Neutrals are warm-tinted; no pure black or white. Every text/background
        pair passes WCAG AA (see DESIGN.md). Use these via AppThemeBinding.
    -->

    <!-- Brand -->
    <Color x:Key="Primary">#C6410F</Color>
    <Color x:Key="PrimaryDark">#F0895C</Color>
    <Color x:Key="Accent">#0E7C86</Color>
    <Color x:Key="AccentDark">#4FC4D6</Color>
    <Color x:Key="Secondary">#F2A03D</Color>

    <!-- Neutrals -->
    <Color x:Key="Background">#F7F5F2</Color>
    <Color x:Key="BackgroundDark">#1A1712</Color>
    <Color x:Key="Surface">#FFFFFF</Color>
    <Color x:Key="SurfaceDark">#24211B</Color>
    <Color x:Key="TextPrimary">#1E1B18</Color>
    <Color x:Key="TextPrimaryDark">#ECE8E2</Color>
    <Color x:Key="TextSecondary">#6B6560</Color>
    <Color x:Key="TextSecondaryDark">#A39D95</Color>

    <!-- Semantic -->
    <Color x:Key="Success">#2E8B57</Color>
    <Color x:Key="Warning">#E8A317</Color>
    <Color x:Key="Error">#D2402F</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Surface}" />
</ResourceDictionary>
